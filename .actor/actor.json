{
  "actorSpecification": 1,
  "name": "booking-com-hotel-scraper",
  "title": "Booking.com Hotel Scraper - Prices, Reviews & Availability",
  "description": "Collect public Booking.com hotel and accommodation listing data including prices, ratings, review counts, cancellation options, amenities, and property URLs.",
  "version": "1.0",
  "categories": ["TRAVEL", "PRICE_COMPARISON"],
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "output": "./output_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "hotels": {
          "title": "Hotel Records",
          "transformation": {
            "fields": [
              "destination",
              "hotelName",
              "starRating",
              "guestReviewScore",
              "reviewCount",
              "totalPrice",
              "pricePerNight",
              "currency",
              "city",
              "country",
              "distanceFromCityCenter",
              "freeCancellation",
              "propertyUrl",
              "propertyId",
              "scrapedAt"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "destination": { "label": "Destination", "format": "text" },
              "hotelName": { "label": "Hotel", "format": "text" },
              "starRating": { "label": "Stars", "format": "number" },
              "guestReviewScore": { "label": "Guest Score", "format": "number" },
              "reviewCount": { "label": "Reviews", "format": "number" },
              "totalPrice": { "label": "Total Price", "format": "number" },
              "pricePerNight": { "label": "Per Night", "format": "number" },
              "currency": { "label": "Currency", "format": "text" },
              "city": { "label": "City", "format": "text" },
              "country": { "label": "Country", "format": "text" },
              "distanceFromCityCenter": { "label": "Distance From City Center", "format": "text" },
              "freeCancellation": { "label": "Free Cancellation", "format": "text" },
              "propertyUrl": { "label": "URL", "format": "link" },
              "propertyId": { "label": "Property ID", "format": "text" },
              "scrapedAt": { "label": "Scraped At", "format": "date" }
            }
          }
        }
      }
    }
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor start",
          "eventDescription": "Charged when the run starts to cover browser startup and residential proxy setup. Number of events depends on memory (one per GB, minimum one).",
          "eventPriceUsd": 0.001,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "booking-search-started": {
          "eventTitle": "Destination search started",
          "eventDescription": "Charged once for each Booking.com destination search that starts, covering browser, navigation, and proxy overhead even when no hotels match the filters.",
          "eventPriceUsd": 0.05,
          "isPrimaryEvent": false,
          "isOneTimeEvent": false
        },
        "hotel-scraped": {
          "eventTitle": "Hotel scraped",
          "eventDescription": "Charged once for each clean Booking.com hotel record saved to the dataset.",
          "eventPriceUsd": 0.008,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 2048,
    "timeoutSecs": 1200
  },
  "minMemoryMbytes": 2048,
  "maxMemoryMbytes": 2048,
  "webScraper": false
}
